# === Gemini API ===
# Obtén tu key en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_aqui

# === Telegram (opcional) ===
# Si lo dejas vacío, el canal Telegram no se activa
TELEGRAM_BOT_TOKEN=

# === Puerto del dashboard web ===
HOST_PORT=160206

# === Gateway auth token ===
OPENCLAW_GATEWAY_TOKEN=estudio_token

# === IP pública (para el dashboard desde otros dispositivos) ===
PUBLIC_IP=localhost
